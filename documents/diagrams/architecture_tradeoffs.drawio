<?xml version='1.0' encoding='utf-8'?>
<mxfile host="Electron" type="device">
  <diagram id="architectural_tradeoffs" name="Architecture Tradeoffs">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg_0" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#E2E8F0;strokeWidth=2;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="30" y="30" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="border_0" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#3B50D2;strokeColor=none;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="30" width="6" height="240" as="geometry" />
        </mxCell>
        <mxCell id="title_0" value="LLM + Chain-of-Thought Reasoning" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#3B50D2;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="45" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub_0" value="vs. Rule-based systems / Classical ML" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#9CA3AF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="55" y="70" width="420" height="20" as="geometry" />
        </mxCell>
        <mxCell id="body_0" value="Generalizes across novel targets, generates multi-step attack plans, interprets raw tool output. Rules can't cover every engagement surface." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#4B5563;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="55" y="105" width="420" height="60" as="geometry" />
        </mxCell>
        <mxCell id="chosen_0" value="Chosen: LLMs with CoT prompting" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#3B50D2;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=left;spacingLeft=15;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="175" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="trade_0" value="⚠️ Tradeoff: Mitigated by Analyzer Verification tier requiring evidence before promotion." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#6B7280;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="55" y="225" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bg_1" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#E2E8F0;strokeWidth=2;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="510" y="30" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="border_1" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#1E293B;strokeColor=none;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="30" width="6" height="240" as="geometry" />
        </mxCell>
        <mxCell id="title_1" value="RAG — Retrieval-Augmented Generation" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#1E293B;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="535" y="45" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub_1" value="vs. Fine-tuning / Static system prompts" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#9CA3AF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="535" y="70" width="420" height="20" as="geometry" />
        </mxCell>
        <mxCell id="body_1" value="Decouples knowledge from model weights. CVEs published daily make fine-tuning unsustainable. Context window too small for full CVE/TTP breadth." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#4B5563;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="535" y="105" width="420" height="60" as="geometry" />
        </mxCell>
        <mxCell id="chosen_1" value="Chosen: RAG + Qdrant vector DB with per-domain indexes" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#1E293B;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=left;spacingLeft=15;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="535" y="175" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="trade_1" value="⚠️ Tradeoff: Retrieval quality depends on embedding model &amp; chunking strategy." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#6B7280;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="535" y="225" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bg_2" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#E2E8F0;strokeWidth=2;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="30" y="290" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="border_2" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#06B6D4;strokeColor=none;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="290" width="6" height="240" as="geometry" />
        </mxCell>
        <mxCell id="title_2" value="Multi-Agent System (MAS)" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#06B6D4;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="305" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub_2" value="vs. Single monolithic agent" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#9CA3AF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="55" y="330" width="420" height="20" as="geometry" />
        </mxCell>
        <mxCell id="body_2" value="Recon, exploitation, verification, and reporting each need different tool sets. Single agent saturates context window on deep engagements." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#4B5563;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="55" y="365" width="420" height="60" as="geometry" />
        </mxCell>
        <mxCell id="chosen_2" value="Chosen: Specialized agents (Planner, Executor, Analyzer) + centralized Orchestrator" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#06B6D4;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=left;spacingLeft=15;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="435" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="trade_2" value="⚠️ Tradeoff: Coordination complexity handled by LangGraph state machine." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#6B7280;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="55" y="485" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="bg_3" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#FFFFFF;strokeColor=#E2E8F0;strokeWidth=2;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="510" y="290" width="460" height="240" as="geometry" />
        </mxCell>
        <mxCell id="border_3" value="" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#6366F1;strokeColor=none;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="290" width="6" height="240" as="geometry" />
        </mxCell>
        <mxCell id="title_3" value="SSVC Vulnerability Prioritization" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#6366F1;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="535" y="305" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sub_3" value="vs. CVSS scoring only" style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#9CA3AF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="535" y="330" width="420" height="20" as="geometry" />
        </mxCell>
        <mxCell id="body_3" value="CVSS assigns the same score regardless of deployment context. A CVSS 9.8 on an air-gapped server can be less urgent than a CVSS 6.5 on a payment API." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#4B5563;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="535" y="365" width="420" height="60" as="geometry" />
        </mxCell>
        <mxCell id="chosen_3" value="Chosen: SSVC (ACT / ATTEND / TRACK decisions) backed by NVD + CISA KEV + EPSS" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#6366F1;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;align=left;spacingLeft=15;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="535" y="435" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="trade_3" value="⚠️ Tradeoff: Requires enrichment data — supplied by Intel Agent via continuous RAG updates." style="text;html=0;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontColor=#6B7280;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="535" y="485" width="420" height="30" as="geometry" />
        </mxCell>
      </root>
