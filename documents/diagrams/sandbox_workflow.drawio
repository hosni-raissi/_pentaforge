<?xml version='1.0' encoding='utf-8'?>
<mxfile host="Electron" type="device">
  <diagram id="sandbox_flow" name="Sandbox Workflow">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="agent" value="&lt;b style='color:#FFFFFF;font-size:16px;'&gt;Agent request&lt;/b&gt;&lt;br&gt;&lt;span style='color:#E0E7FF;font-size:13px;'&gt;Incoming instruction from agent&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;ushadow=1;fillColor=#4F46E5;" vertex="1" parent="1">
          <mxGeometry x="320" y="50" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="router" value="&lt;b style='color:#FFFFFF;font-size:16px;'&gt;Tool routing&lt;/b&gt;&lt;br&gt;&lt;span style='color:#D1FAE5;font-size:13px;'&gt;Matched against catalog: Nmap • ffuf • curl • SQLMap • Nikto&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;ushadow=1;fillColor=#10B981;" vertex="1" parent="1">
          <mxGeometry x="250" y="150" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cont1" value="&lt;i&gt;&lt;span style='color:#64748B;font-size:14px;'&gt;Execution guards — three-layer policy enforcement&lt;/span&gt;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;dashPattern=1 2;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="160" y="250" width="680" height="240" as="geometry" />
        </mxCell>
        <mxCell id="scope" value="&lt;b style='color:#FFFFFF;font-size:16px;'&gt;Scope&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='color:#FEF3C7;font-size:13px;'&gt;Is the target within&lt;br&gt;the authorized&lt;br&gt;engagement perimeter?&lt;/span&gt;&lt;br&gt;&lt;div style='border: 1px solid #FEF3C7; border-radius: 4px; padding: 4px 10px; display: inline-block; font-size: 12px; color: #FEF3C7; margin-top: 20px;'&gt;✓ / ✗ Pass / Block&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#F59E0B;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="290" width="200" height="180" as="geometry" />
        </mxCell>
        <mxCell id="role" value="&lt;b style='color:#FFFFFF;font-size:16px;'&gt;Role&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='color:#FEF3C7;font-size:13px;'&gt;Does the requesting&lt;br&gt;agent have permission&lt;br&gt;to run this tool?&lt;/span&gt;&lt;br&gt;&lt;div style='border: 1px solid #FEF3C7; border-radius: 4px; padding: 4px 10px; display: inline-block; font-size: 12px; color: #FEF3C7; margin-top: 20px;'&gt;✓ / ✗ Pass / Block&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#F59E0B;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="290" width="200" height="180" as="geometry" />
        </mxCell>
        <mxCell id="policy" value="&lt;b style='color:#FFFFFF;font-size:16px;'&gt;Policy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='color:#FEF3C7;font-size:13px;'&gt;Does the command&lt;br&gt;violate any rules&lt;br&gt;of engagement?&lt;/span&gt;&lt;br&gt;&lt;div style='border: 1px solid #FEF3C7; border-radius: 4px; padding: 4px 10px; display: inline-block; font-size: 12px; color: #FEF3C7; margin-top: 20px;'&gt;✓ / ✗ Pass / Block&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;fillColor=#F59E0B;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="290" width="200" height="180" as="geometry" />
        </mxCell>
        <mxCell id="client" value="&lt;b style='color:#FFFFFF;font-size:16px;'&gt;Sandbox client&lt;/b&gt;&lt;br&gt;&lt;span style='color:#DBEAFE;font-size:13px;'&gt;Dispatches every tool call to isolated sandbox service&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=0;ushadow=1;fillColor=#3B82F6;" vertex="1" parent="1">
          <mxGeometry x="250" y="530" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cont2" value="&lt;i&gt;&lt;span style='color:#64748B;font-size:14px;'&gt;Docker isolation — decoupled from backend &amp;amp; frontend&lt;/span&gt;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#CBD5E1;strokeWidth=2;dashed=1;dashPattern=1 2;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="160" y="630" width="680" height="200" as="geometry" />
        </mxCell>
        <mxCell id="tool_Nmap" value="Nmap" style="rounded=1;whiteSpace=wrap;html=0;strokeWidth=0;fillColor=#F43F5E;shadow=1;fontColor=#FFFFFF;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="670" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tool_ffuf" value="ffuf" style="rounded=1;whiteSpace=wrap;html=0;strokeWidth=0;fillColor=#F43F5E;shadow=1;fontColor=#FFFFFF;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="315" y="670" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tool_curl" value="curl" style="rounded=1;whiteSpace=wrap;html=0;strokeWidth=0;fillColor=#F43F5E;shadow=1;fontColor=#FFFFFF;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="670" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tool_SQLMap" value="SQLMap" style="rounded=1;whiteSpace=wrap;html=0;strokeWidth=0;fillColor=#F43F5E;shadow=1;fontColor=#FFFFFF;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="565" y="670" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tool_Nikto" value="Nikto" style="rounded=1;whiteSpace=wrap;html=0;strokeWidth=0;fillColor=#F43F5E;shadow=1;fontColor=#FFFFFF;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="670" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="executor" value="&lt;b style='color:#1E293B;font-size:16px;'&gt;Executor&lt;/b&gt;&lt;br&gt;&lt;span style='color:#475569;font-size:13px;'&gt;Runs command in isolation — no access to host machine&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#CBD5E1;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="760" width="620" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="agent" target="router">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="router" target="cont1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="cont1" target="client">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="client" target="cont2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tool_Nmap" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="tool_Nmap" target="executor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tool_ffuf" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="tool_ffuf" target="executor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tool_curl" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="tool_curl" target="executor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tool_SQLMap" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="tool_SQLMap" target="executor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tool_Nikto" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94A3B8;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="tool_Nikto" target="executor">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>