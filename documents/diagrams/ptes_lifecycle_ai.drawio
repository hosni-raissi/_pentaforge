        </mxCell>
        <mxCell id="table" value="&#10;    &lt;table style=&quot;width:100%; border-collapse: collapse; font-family: Helvetica, Arial, sans-serif; font-size: 13px;&quot;&gt;&#10;      &lt;tr style=&quot;background-color: #111827; color: #FFFFFF; height: 38px; text-align: left;&quot;&gt;&#10;        &lt;th style=&quot;padding-left: 15px; width: 25%;&quot;&gt;Phase&lt;/th&gt;&#10;        &lt;th style=&quot;width: 55%;&quot;&gt;AI Contribution&lt;/th&gt;&#10;        &lt;th style=&quot;width: 20%; text-align: center;&quot;&gt;Estimated Gain&lt;/th&gt;&#10;      &lt;/tr&gt;&#10;      &lt;tr style=&quot;border-bottom: 1px solid #E5E7EB; height: 48px; color: #4B5563;&quot;&gt;&#10;        &lt;td style=&quot;padding-left: 15px; font-weight: bold; color: #1E3A8A;&quot;&gt;Reconnaissance&lt;/td&gt;&#10;        &lt;td&gt;Multi-source OSINT automation &amp;amp; target-context synthesis&lt;/td&gt;&#10;        &lt;td style=&quot;text-align: center; font-weight: bold; color: #1E3A8A;&quot;&gt;-35% time&lt;/td&gt;&#10;      &lt;/tr&gt;&#10;      &lt;tr style=&quot;border-bottom: 1px solid #E5E7EB; height: 48px; color: #4B5563;&quot;&gt;&#10;        &lt;td style=&quot;padding-left: 15px; font-weight: bold; color: #1D4ED8;&quot;&gt;Scanning &amp;amp; Enumeration&lt;/td&gt;&#10;        &lt;td&gt;Intelligent target prioritisation &amp;amp; adaptive test selection&lt;/td&gt;&#10;        &lt;td style=&quot;text-align: center; font-weight: bold; color: #1D4ED8;&quot;&gt;-50% time&lt;/td&gt;&#10;      &lt;/tr&gt;&#10;      &lt;tr style=&quot;border-bottom: 1px solid #E5E7EB; height: 48px; color: #4B5563;&quot;&gt;&#10;        &lt;td style=&quot;padding-left: 15px; font-weight: bold; color: #2563EB;&quot;&gt;Exploitation&lt;/td&gt;&#10;        &lt;td&gt;Contextual payload generation adapted to observed behaviour&lt;/td&gt;&#10;        &lt;td style=&quot;text-align: center; font-weight: bold; color: #2563EB;&quot;&gt;Qualitative&lt;/td&gt;&#10;      &lt;/tr&gt;&#10;      &lt;tr style=&quot;border-bottom: 1px solid #E5E7EB; height: 48px; color: #4B5563;&quot;&gt;&#10;        &lt;td style=&quot;padding-left: 15px; font-weight: bold; color: #3B82F6;&quot;&gt;Post-Exploitation&lt;/td&gt;&#10;        &lt;td&gt;Automated lateral movement analysis &amp;amp; privilege escalation pathing&lt;/td&gt;&#10;        &lt;td style=&quot;text-align: center; font-weight: bold; color: #3B82F6;&quot;&gt;-40% time&lt;/td&gt;&#10;      &lt;/tr&gt;&#10;      &lt;tr style=&quot;height: 48px; color: #4B5563;&quot;&gt;&#10;        &lt;td style=&quot;padding-left: 15px; font-weight: bold; color: #0284C7;&quot;&gt;Reporting&lt;/td&gt;&#10;        &lt;td&gt;Structured report generation from verified findings &amp;amp; evidence&lt;/td&gt;&#10;        &lt;td style=&quot;text-align: center; font-weight: bold; color: #0284C7;&quot;&gt;-35% time&lt;/td&gt;&#10;      &lt;/tr&gt;&#10;    &lt;/table&gt;&#10;    " style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
