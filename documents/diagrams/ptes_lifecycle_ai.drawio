        <mxCell id="time_estimates" value="&lt;span style='font-size:12px;color:#4B5563;line-height:1.6;'&gt;Manual cycle: &lt;b&gt;2-4 weeks&lt;/b&gt;&lt;br&gt;AI-assisted: &lt;b style='color:#1E3A8A;'&gt;hours&lt;/b&gt;&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
