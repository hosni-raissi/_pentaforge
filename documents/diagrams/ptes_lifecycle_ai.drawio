        <mxCell id="insight_text" value="&lt;div style='padding-left:15px;padding-right:15px;font-size:13px;color:#374151;line-height:1.5;'&gt;&lt;b style='color:#3949AB;'&gt;Key insight:&lt;/b&gt; AI reduces the automatable phases from weeks to hours — freeing pentesters to focus on high-value manual tasks and creative attack chaining.&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
