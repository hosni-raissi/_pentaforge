  "infra": [
    {
      "id": "passive_context",
      "block_name": "Passive Context",
      "interaction": "passive",
      "goal": "Collect passive domain, DNS, ownership, and certificate context before active checks.",
      "tools": [
        {
          "name": "run_custom",
          "args": ["whois", "trgt"]
        },
        {
          "name": "run_custom",
          "args": ["dig", "trgt", "A", "+short"]
        },
        {
          "name": "run_custom",
          "args": ["dig", "trgt", "AAAA", "+short"]
        },
        {
          "name": "run_custom",
          "args": ["dig", "trgt", "MX", "+short"]
        },
        {
          "name": "run_custom",
          "args": ["dig", "trgt", "NS", "+short"]
        },
        {
          "name": "run_custom",
          "args": ["dig", "trgt", "TXT", "+short"]
        },
        {
          "name": "run_custom",
          "args": ["tlsx", "-u", "trgt", "-json", "-silent"]
        }
      ]
    },
    {
      "id": "dns_surface",
      "block_name": "DNS Surface",
      "interaction": "active_safe",
      "goal": "Collect DNS records, CDN hints, mail records, and cloud indicators with low-noise DNS queries.",
      "tools": [
        {
          "name": "run_custom",
          "args": [
            "dnsx",
            "-d",
            "trgt",
            "-a",
            "-aaaa",
            "-cname",
            "-mx",
            "-ns",
            "-txt",
            "-resp",
            "-silent",
            "-json"
          ]
        },
        {
          "name": "run_custom",
          "args": [
            "subfinder",
            "-d",
            "trgt",
            "-all",
            "-recursive",
            "-silent"
          ]
        }
      ]
    },
    {
      "id": "path_and_routing",
      "block_name": "Path And Routing",
      "interaction": "active_safe",
      "goal": "Map basic network path and routing behavior with limited packet count.",
      "tools": [
        {
          "name": "run_custom",
          "args": [
            "sudo",
            "mtr",
            "--report",
            "--report-wide",
            "--json",
            "--show-ips",
            "--tcp",
            "-c",
            "10",
            "-m",
            "30",
            "trgt"
          ]
        },
        {
          "name": "run_custom",
          "args": [
            "sudo",
            "traceroute",
            "-T",
            "-m",
            "30",
            "trgt"
          ]
        }
      ]
    },
    {
      "id": "service_inventory",
      "block_name": "Service Inventory",
      "interaction": "active_safe",
      "goal": "Identify common exposed services using conservative timing and limited ports.",
      "tools": [
        {
          "name": "run_custom",
          "args": [
            "sudo",
            "nmap",
            "-sS",
            "-sV",
            "-Pn",
            "-n",
            "-T3",
            "--max-retries",
            "2",
            "--version-intensity",
            "2",
            "-p",
            "21,22,25,53,80,110,143,443,465,587,993,995,1433,1521,2049,2375,2376,3306,3389,5432,5900,5985,5986,6379,8080,8443,9200,9300,11211,27017",
            "--reason",
            "-oX",
            "-",
            "trgt"
          ]
        }
      ]
    },
    {
      "id": "http_service_fingerprint",
      "block_name": "HTTP Service Fingerprint",
      "interaction": "active_safe",
      "goal": "Fingerprint HTTP services, CDN, status code, title, redirects, and detected technologies.",
      "tools": [
        {
          "name": "run_custom",
          "args": [
            "httpx",
            "-u",
            "trgt",
            "-silent",
            "-json",
            "-ip",
            "-cdn",
            "-td",
            "-sc",
            "-title",
            "-cl",
            "-rt",
            "-follow-redirects",
            "-timeout",
            "15"
          ]
        },
        {
          "name": "run_custom",
          "args": [
            "curl",
            "-k",
            "-I",
            "-L",
            "--max-time",
            "15",
            "full_trgt"
          ]
        }
      ]
    },
    {
      "id": "safe_vuln_context",
      "block_name": "Safe Vulnerability Context",
      "interaction": "active_safe",
      "goal": "Run low-rate known exposure and misconfiguration checks without exploit-heavy templates.",
      "tools": [
        {
          "name": "run_custom",
          "args": [
            "nuclei",
            "-u",
            "full_trgt",
            "-silent",
            "-json",
            "-severity",
            "low,medium,high,critical",
            "-tags",
            "cve,exposure,misconfig,panel",
            "-exclude-tags",
            "bruteforce,rce,lpe,dos,intrusive",
            "-rate-limit",
            "10",
            "-retries",
            "1",
            "-timeout",
            "10"
          ]
        }
      ]
    }
  ],
