  "mobile": [
    {
      "id": "artifact_profile",
      "block_name": "Artifact Profile",
      "interaction": "static",
      "goal": "Identify mobile artifact type, hash, package metadata, and static indicators without writing output files.",
      "tools": [
        {
          "name": "run_custom",
          "args": ["file", "trgt"]
        },
        {
          "name": "run_custom",
          "args": ["sha256sum", "trgt"]
        },
        {
          "name": "run_custom",
          "args": ["apkid", "trgt"]
        },
        {
          "name": "run_custom",
          "args": ["aapt", "dump", "badging", "trgt"]
        },
        {
          "name": "run_custom",
          "args": ["aapt", "dump", "permissions", "trgt"]
        }
      ]
    },
    {
      "id": "archive_and_manifest_review",
      "block_name": "Archive And Manifest Review",
      "interaction": "static",
      "goal": "List mobile archive content and manifest indicators without extracting files.",
      "tools": [
        {
          "name": "run_custom",
          "args": ["unzip", "-l", "trgt"]
        },
        {
          "name": "run_custom",
          "args": ["aapt", "dump", "xmltree", "trgt", "AndroidManifest.xml"]
        }
      ]
    },
    {
      "id": "static_security_scan",
      "block_name": "Static Security Scan",
      "interaction": "static",
      "goal": "Run mobile static security checks without dynamic execution or file output.",
      "tools": [
        {
          "name": "run_custom",
          "args": ["mobsfscan", "--json", "trgt"]
        },
        {
          "name": "run_custom",
          "args": ["apkleaks", "-f", "trgt"]
        }
      ]
    },
    {
      "id": "secret_and_endpoint_review",
      "block_name": "Secret And Endpoint Review",
      "interaction": "static",
      "goal": "Search for hardcoded secrets, URLs, tokens, keys, and backend endpoints without writing output files.",
      "tools": [
        {
          "name": "run_custom",
          "args": [
            "strings",
            "trgt",
            "|",
            "grep",
            "-Ei",
            "https?://|password|secret|api_key|apikey|token|private_key|jdbc|connection_string|firebase|s3|aws|azure|gcp|bearer"
          ]
        },
        {
          "name": "run_custom",
          "args": [
            "trufflehog",
            "filesystem",
            "trgt",
            "--json",
            "--no-update"
          ]
        }
      ]
    }
  ],
