{
  "web_app": [
    {
      "id": "passive_context",
      "block_name": "Passive Context",
      "interaction": "passive",
      "goal": "Collect passive hostname, DNS, and archive context before active checks.",
      "tools": [
        {
          "name": "passive_web_recon"
        },
        {
          "name": "dns_recon"
        },
        {
          "name": "run_custom",
          "args": ["assetfinder", "--subs-only", "target"]
        }
      ]
    },
    {
      "id": "fingerprinting",
      "block_name": "Fingerprinting",
      "interaction": "active_safe",
      "goal": "Identify live web behavior, headers, and technology fingerprints with low-noise wrappers.",
      "tools": [
        {
          "name": "http_probe"
        },
        {
          "name": "detect_tech"
        },
        {
          "name": "http_header_analysis"
        }
      ]
    },
    {
      "id": "known_vuln_fast_lane",
      "block_name": "Known Vulnerability Fast Lane",
      "interaction": "active_safe",
      "goal": "Turn corroborated fingerprints into selective vulnerability intelligence.",
      "tools": [
        {
          "name": "known_vuln_lookup"
        }
      ]
    },
    {
      "id": "surface_mapping",
      "block_name": "Surface Mapping",
      "interaction": "active_safe",
      "goal": "Map reachable routes and passive URL clues without jumping into aggressive fuzzing.",
      "tools": [
        {
          "name": "web_crawler"
        },
        {
          "name": "api_endpoint_discovery"
        },
        {
          "name": "run_custom",
          "args": ["gau", "target"]
        }
      ]
    },
    {
      "id": "trust_and_auth",
      "block_name": "Trust And Auth",
      "interaction": "active_safe",
      "goal": "Check for trust-boundary and session-handling exposure using safe wrappers.",
      "tools": [
        {
          "name": "cors_misconfig_check"
        },
        {
          "name": "session_token_analysis"
        }
      ]
    }
  ],
