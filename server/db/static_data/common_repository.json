{
  "framework_name": "Core 8 Repository Reconnaissance Framework",
  "version": "1.0",
  "scenarios": [
    {
      "id": "R1",
      "scenario": "Commit History & Secret Hunting",
      "objective": "Scan the entire commit log for deleted secrets, hardcoded API keys, and credentials.",
      "methods": ["Git history 'grave digging'", "Regex-based secret scanning", "Entropy-based string analysis"],
      "priority": 1
    },
    {
      "id": "R2",
      "scenario": "Branch & Tag Exploration",
      "objective": "Identify staging, development, or 'feature' branches that lack production-grade security.",
      "methods": ["Stale branch enumeration", "Version tag review", "Release candidate analysis"],
      "priority": 1
    },
    {
      "id": "R3",
      "scenario": "Configuration & Environment Leakage",
      "objective": "Locate sensitive config files like .env, web.config, docker-compose.yml, or .kube/config.",
      "methods": ["File-type dorking", "Infrastructure-as-Code (IaC) review", "Hidden file discovery"],
      "priority": 1
    },
    {
      "id": "R4",
      "scenario": "Dependency & Supply Chain Mapping",
      "objective": "Identify vulnerable third-party libraries and internal private packages.",
      "methods": ["Manifest analysis (package.json, requirements.txt)", "Lockfile auditing", "Dependency tree mapping"],
      "priority": 2
    },
    {
      "id": "R5",
      "scenario": "CI/CD Pipeline & Workflow Analysis",
      "objective": "Analyze build scripts and CI/CD configs for deployment targets and runner secrets.",
      "methods": ["GitHub Actions/GitLab CI yaml review", "Build script inspection", "Artifact destination mapping"],
      "priority": 2
    },
    {
      "id": "R6",
      "scenario": "Contributor & Metadata Profiling",
      "objective": "Extract developer identities, email addresses, and commit patterns to craft social engineering or target dev machines.",
      "methods": ["Author metadata extraction", "Commit timestamp analysis", "Contributor relationship mapping"],
      "priority": 2
    },
    {
      "id": "R7",
      "scenario": "Issue Tracker & Documentation Review",
      "objective": "Scan 'closed' issues, pull request comments, and READMEs for technical hints or internal IP addresses.",
      "methods": ["PR comment scraping", "Issue ticket analysis", "Wiki/Documentation dorking"],
      "priority": 3
    },
    {
      "id": "R8",
      "scenario": "Hook & Submodule Audit",
      "objective": "Identify linked submodules or pre-commit hooks that may lead to secondary repos or internal tools.",
      "methods": [".gitmodules analysis", "Hook script review", "Remote-origin verification"],
      "priority": 3
    }
  ]
}