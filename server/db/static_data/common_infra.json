{
  "framework_name": "Core 8 Infrastructure Reconnaissance Framework",
  "version": "1.0",
  "scenarios": [
    {
      "id": "IN1",
      "scenario": "Network Topology & Routing Discovery",
      "objective": "Map the path of data packets and identify internal routers, hops, and gateways.",
      "methods": ["Traceroute analysis", "BGP prefix tracking", "ICMP path discovery", "Autonomous System (AS) mapping"],
      "priority": 1
    },
    {
      "id": "IN2",
      "scenario": "Virtualization & Hypervisor Detection",
      "objective": "Determine if the target is running on VMware, Hyper-V, KVM, or Xen to target the underlying host.",
      "methods": ["MAC address OUI analysis", "Hardware abstraction leakage", "Hypervisor-specific port probing (e.g., 902/TCP)"],
      "priority": 1
    },
    {
      "id": "IN3",
      "scenario": "Directory Services & Domain Mapping",
      "objective": "Identify the central source of truth for identity, such as Active Directory (AD) or LDAP.",
      "methods": ["DNS SRV record lookup", "LDAP anonymous binding checks", "SMB domain enumeration"],
      "priority": 1
    },
    {
      "id": "IN4",
      "scenario": "Monitoring & Logging Infrastructure",
      "objective": "Locate the 'eyes' of the network—SIEMs, SNMP managers, and log aggregators.",
      "methods": ["SNMP community string probing", "Syslog port detection", "Monitoring agent fingerprinting (e.g., Zabbix, Datadog)"],
      "priority": 2
    },
    {
      "id": "IN5",
      "scenario": "Remote Management & IPMI Review",
      "objective": "Find 'out-of-band' management interfaces like iDRAC, iLO, or IP-KVMs that bypass the OS.",
      "methods": ["IPMI/RMCP+ protocol detection", "Default vendor port scanning", "Web-based BMC discovery"],
      "priority": 2
    },
    {
      "id": "IN6",
      "scenario": "VPN & Border Gateway Analysis",
      "objective": "Identify the secure tunnels into the network and their associated encryption protocols.",
      "methods": ["IKE/IPsec transform probing", "SSL-VPN portal fingerprinting", "Client-side software identification"],
      "priority": 2
    },
    {
      "id": "IN7",
      "scenario": "Internal Trust & Segmentation Audit",
      "objective": "Determine if the network is 'flat' or properly segmented using VLANs or Firewalls.",
      "methods": ["Egress filtering tests", "VLAN hopping checks", "Internal broadcast sniffing"],
      "priority": 3
    },
    {
      "id": "IN8",
      "scenario": "Supply Chain & Third-Party Linkage",
      "objective": "Map dependencies on managed service providers (MSPs) or shared infrastructure vendors.",
      "methods": ["Public record correlation", "Support portal discovery", "Managed DNS/Email provider review"],
      "priority": 3
    }
  ]
}