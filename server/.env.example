# ─── Agent LLM Mode ──────────────────────────────────────────────
# Product builds do not ship LLM profiles or API keys in .env.
# Configure provider, model, API URL, roles, and keys from Settings in the UI.
AGENT_LLM_MODE=public

# ── PostgreSQL ────────────────────────────────────────────────────────────
PG_PASSWORD=your_secure_postgres_password_here

# ── Database (PostgreSQL — document store + source registry) ─────────
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ── Qdrant (vector store — embeddings + metadata index) ──────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Redis (cache — hot queries + recent results) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# github token 
GITHUB_TOKEN=your_github_personal_access_token_here

# Project database (local sqlite file)
PROJECTS_DB_PATH=server/db/projects/projects.db

# ── Web UI Authentication ────────────────────────────────────────────────
WEB_UI_PASSWORD=your_secure_web_ui_password_here
WEB_UI_AUTH_SECRET=your_randomly_generated_auth_secret_here
WEB_UI_AUTH_TTL_SECONDS=28800

# LLM assistant and architect profiles are also configured from Settings.

# ── LLM Rate Limiting ───────────────────────────────────────────────────
GLOBAL_LLM_QUEUE_MAX_CONCURRENT=8